        <mxCell id="KcZ0zRsaBRRgiB3xQfuk-19" parent="KcZ0zRsaBRRgiB3xQfuk-14" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#008a00;fontColor=#ffffff;strokeColor=#005700;" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;&lt;b&gt;Children, 7-12 years old, are recorded via&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;10-20 standard by 19 channels EEG configuration sampled at 128hz&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="190" x="195" y="60" as="geometry" />
        </mxCell>
        <mxCell id="KcZ0zRsaBRRgiB3xQfuk-21" parent="KcZ0zRsaBRRgiB3xQfuk-14" style="swimlane;whiteSpace=wrap;html=1;" value="Visual Task" vertex="1">
          <mxGeometry height="320" width="525" x="27.5" y="350" as="geometry" />
        </mxCell>
        <mxCell id="KcZ0zRsaBRRgiB3xQfuk-22" parent="KcZ0zRsaBRRgiB3xQfuk-21" style="text;html=1;whiteSpace=wrap;strokeColor=#6F0000;fillColor=#a20025;align=center;verticalAlign=middle;rounded=0;fontColor=#ffffff;" value="&lt;span style=&quot;font-family: &amp;quot;Open Sans&amp;quot;, sans-serif; text-align: start;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(202, 206, 209), rgb(0, 0, 0)); font-size: 17px;&quot;&gt;&lt;b&gt;a set of pictures of cartoon characters was shown to the children and they were asked to count the characters. The number of characters in each image was randomly selected between 5 and 16, and the size of the pictures was large enough to be easily visible and countable by children. To have a continuous stimulus during the signal recording, each image was displayed immediately and uninterrupted after the child’s response. Thus, the duration of EEG recording throughout this cognitive visual task was dependent on the child’s performance (i.e. response speed).&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="270" width="500" x="10" y="30" as="geometry" />
        </mxCell>
